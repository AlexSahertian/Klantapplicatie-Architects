@page
@model KE03_INTDEV_SE_1_Base.Pages.Parts.IndexModel

@{
    ViewData["Title"] = "Onderdelen";
}

<section class="page-hero parts-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="section-label">Technische catalogus</span>

                <h1 class="fw-bold display-5">
                    Matrix onderdelen
                </h1>

                <p class="lead">
                    Bekijk technische onderdelen die gebruikt kunnen worden voor onderhoud,
                    reparatie en uitbreiding van Matrix-apparatuur.
                </p>
            </div>

            <div class="col-lg-4 text-lg-end">
                <a asp-page="/Products/Index" class="btn btn-light btn-lg">
                    Terug naar producten
                </a>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="shop-toolbar mb-4">
        <div>
            <h2 class="fw-bold mb-1">Onderdelencatalogus</h2>
            <p class="text-muted mb-0">
                @Model.Parts.Count onderdelen beschikbaar
            </p>
        </div>

        <div class="toolbar-chip">
            Technische specificaties
        </div>
    </div>

    <div class="row g-4">
        @foreach (var part in Model.Parts)
        {
            <div class="col-lg-3 col-md-6">
                <div class="part-card h-100">
                    <div class="part-icon">
                        ⚙️
                    </div>

                    <h4 class="fw-bold mt-3">
                        @part.Name
                    </h4>

                    <p class="text-muted">
                        @part.Description
                    </p>

                    <div class="mt-auto">
                        <span class="badge bg-dark">
                            Onderdeel
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>